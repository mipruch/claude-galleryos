{
  // Root project — used by `tsc --noEmit` (full-monorepo type-check) and editors.
  // Workspace packages (`@gallery/*`) resolve through bun's node_modules symlinks,
  // so no `paths` mapping is needed.
  "extends": "./tsconfig.base.json",
  // apps/ui uses vue-tsc + browser/DOM types; excluded from this Bun-typed check.
  // Run `bun run typecheck:ui` to type-check the frontend separately.
  "exclude": ["apps/ui"],
  "include": [
    "apps/*/src/**/*.ts",
    "packages/driver-core/src/**/*.ts",
    "packages/drivers/*/src/**/*.ts"
  ]
}
