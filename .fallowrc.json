{
	"$schema": "https://raw.githubusercontent.com/fallow-rs/fallow/main/schema.json",
	"entry": ["src/index.{ts,tsx,js,jsx}", "src/main.{ts,tsx,js,jsx}"],
	"workspaces": {
		"packages": ["apps/*", "packages/driver-core", "packages/drivers/*"]
	},
	"duplicates": {
		"minOccurrences": 3,
		"ignore": [
			"**/lib/**",
			"**/dist/**",
			"**/node_modules/**",
			"**/manuals/**",
            "**.test.ts",
            "packages/drivers/driver-**/src/**.ts"
		]
	},
	"rules": {
    },
    "ignorePatterns": ["**/*.generated.ts", "**/*.d.ts", "**/test/**", "**/__tests__/**", "**/*.test.ts", "**/manuals/**", "apps/server/src/db/schema.ts"]

}
