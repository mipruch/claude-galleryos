# ─────────────────────────────────────────────────────────────
# GalleryOS — environment configuration
# Copy to `.env` and adjust. Docker Compose reads this file too.
# ─────────────────────────────────────────────────────────────

# Server
PORT=3000
LOG_LEVEL=debug                # debug | info | warn | error  (use 'info' in production)
NODE_ENV=development

# Database (TimescaleDB / PostgreSQL) — accessed via Bun.sql
DB_PASSWORD=gallery_dev_password
DATABASE_URL=postgresql://gallery:gallery_dev_password@localhost:5432/gallery

# Redis (live state) — accessed via Bun.redis
REDIS_URL=redis://localhost:6379

# Protocol inputs (added in a later step)
OSC_PORT=8765
TCP_INPUT_PORT=8766

# Watchdog
WATCHDOG_CONNECTION_INTERVAL_MS=10000
WATCHDOG_ENDPOINT_INTERVAL_MS=60000

# Driver subprocess restart policy (exponential backoff)
DRIVER_RESTART_MAX_ATTEMPTS=0          # 0 = unlimited
DRIVER_RESTART_BASE_DELAY_MS=1000
DRIVER_RESTART_MAX_DELAY_MS=30000

# Default per-command timeout for drivers (ms)
DRIVER_COMMAND_TIMEOUT_MS=2000

# Logs
LOG_RETENTION_DAYS=90
LOG_FILE_PATH=./logs/gallery.log
