# Database
DB_PASSWORD=gallery_dev_password
DATABASE_URL=postgresql://gallery:gallery_dev_password@postgres:5432/gallery

# Redis
REDIS_URL=redis://redis:6379

# Server
PORT=3000
LOG_LEVEL=info
NODE_ENV=production

# OSC input
OSC_PORT=8765

# TCP input
TCP_INPUT_PORT=8766

# Watchdog
WATCHDOG_CONNECTION_INTERVAL_MS=10000
WATCHDOG_ENDPOINT_INTERVAL_MS=60000

# Driver subprocess
DRIVER_RESTART_MAX_ATTEMPTS=0
DRIVER_RESTART_BASE_DELAY_MS=1000
DRIVER_RESTART_MAX_DELAY_MS=30000

# Logs
LOG_RETENTION_DAYS=90
LOG_FILE_PATH=./logs/gallery.log

# Frontend
VITE_API_URL=http://localhost:3000
